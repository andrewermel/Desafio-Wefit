# WeFit Backend - Configuração de Ambiente

# ========================================
# SERVIDOR
# ========================================

# Porta do servidor Express
PORT=4568

# Ambiente de execução
# Valores: development, production, test
NODE_ENV=development

# ========================================
# BANCO DE DADOS
# ========================================

# Host do MySQL
DB_HOST=localhost

# Porta do MySQL
DB_PORT=3306

# Usuário do MySQL
DB_USER=root

# Senha do MySQL
DB_PASSWORD=senha_root_123

# Nome do banco de dados
DB_NAME=wefit

# ========================================
# NOTAS
# ========================================
# - Docker Compose cria automaticamente o MySQL com estes dados
# - Para roddar testes E2E: NODE_ENV=test
# - Para produção: Usar variáveis de ambiente do servidor
# - Valores padrão já estão configurados no código (veja src/database/connection.ts)
